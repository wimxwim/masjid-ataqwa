# === Supabase (isi setelah provisioning) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Koneksi Postgres untuk Drizzle (Connection string Supabase, mode session/pooler)
DATABASE_URL=

# === Cloudflare Turnstile (anti-spam form publik) ===
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Enkripsi NIK (AES-256-GCM, 32-byte key hex) ===
# Generate: openssl rand -hex 32
NIK_ENCRYPTION_KEY=

# === Midtrans (pembayaran donasi) ===
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# === Fonnte WhatsApp Gateway ===
# Daftar akun: https://fonnte.com
# Token: Settings → Account Token
FONNTE_TOKEN=
FONNTE_PHONE=

# === Analytics ===
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Masjid Jami' At-Taqwa
