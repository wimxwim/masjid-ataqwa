# === Supabase (isi setelah provisioning) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Koneksi Postgres untuk Drizzle (Connection string Supabase, mode session/pooler)
DATABASE_URL=

# === Cloudflare Turnstile (anti-spam form publik) ===
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Midtrans (pembayaran donasi) ===
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=

# === Enkripsi NIK (AES-256-GCM, 32-byte key hex) ===
# Generate: openssl rand -hex 32
NIK_ENCRYPTION_KEY=
