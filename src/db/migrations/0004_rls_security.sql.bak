-- RLS policies untuk keamanan data multi-tenant

-- 1. donations — public bisa insert, hanya pengurus masjid bisa lihat
ALTER TABLE donations ENABLE ROW LEVEL SECURITY;

CREATE POLICY donations_insert_public ON donations
  FOR INSERT
  WITH CHECK (true);

CREATE POLICY donations_select_admin ON donations
  FOR SELECT
  USING (
    mosque_id IN (
      SELECT mosque_id FROM profiles
      WHERE id = auth.uid() AND deleted_at IS NULL
    )
  );

CREATE POLICY donations_update_admin ON donations
  FOR UPDATE
  USING (
    mosque_id IN (
      SELECT mosque_id FROM profiles
      WHERE id = auth.uid() AND deleted_at IS NULL
    )
  );

